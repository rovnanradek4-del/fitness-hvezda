# ─── AUTH ──────────────────────────────────────────────────────────────────────
# Heslo pro přihlášení do aplikace (trenér zadává při každém přihlášení)
APP_PASSWORD=your-login-password-here

# Tajný klíč pro podpis session cookie — náhodný řetězec min. 32 znaků
# Generovat: openssl rand -base64 32
APP_SECRET=generate-a-random-32-char-string-here

# ─── ANTHROPIC AI ──────────────────────────────────────────────────────────────
# API klíč z https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ─── GOOGLE CALENDAR ──────────────────────────────────────────────────────────
# OAuth 2.0 credentials z https://console.cloud.google.com
# Typ aplikace: Web application
# Scopes: https://www.googleapis.com/auth/calendar.readonly
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-client-secret
GOOGLE_REDIRECT_URI=https://your-app.vercel.app/api/auth/google/callback

# ─── SUPABASE ─────────────────────────────────────────────────────────────────
# Projekt URL a service role key z https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── OBSIDIAN / DATA (jen pro lokální migraci) ────────────────────────────────
# Potřeba pouze pro jednorázový migrační script `npm run migrate`
# Na Vercel tato proměnná NENÍ potřeba
# OBSIDIAN_BASE=/Users/jmeno/Library/Mobile Documents/iCloud~md~obsidian/Documents/Fitness Hvězda - Klienti/Klienti
